# ── FIREBASE DATABASE (Firestore) ──
# To connect to Firebase:
# 1. Go to Firebase Console -> Project Settings -> Service Accounts
# 2. Click "Generate new private key"
# 3. Save the downloaded JSON file into this folder and rename it exactly to:
#    serviceAccountKey.json

# ── EMAIL NOTIFICATIONS (Gmail/SendGrid/etc.) ──
# If using Gmail, generate an 'App Password' at https://myaccount.google.com/apppasswords
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
NOTIFY_EMAIL=hr@electronstudios.online

# ── SERVER CONFIG ──
PORT=5000
